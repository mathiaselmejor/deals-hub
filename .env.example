# Copia este archivo a .env.local y rellena tus IDs cuando te aprueben

# Amazon Afiliados (amazon.es) — tu tag tipo "tunombre-21"
NEXT_PUBLIC_AMAZON_TAG=

# Awin — tu Publisher ID (número)
NEXT_PUBLIC_AWIN_PUBLISHER_ID=

# Admitad — opcional
NEXT_PUBLIC_ADMITAD_ID=

# TradeTracker — opcional
NEXT_PUBLIC_TRADETRACKER_ID=

# eBay Partner Network — Campaign ID
NEXT_PUBLIC_EBAY_CAMPAIGN_ID=

# AliExpress Portals — Tracking ID
NEXT_PUBLIC_ALIEXPRESS_TRACKING_ID=

# Booking.com — Affiliate ID
NEXT_PUBLIC_BOOKING_AID=
