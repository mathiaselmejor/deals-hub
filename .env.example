# Copia este archivo a .env.local y rellena tus IDs cuando te aprueben

# ─── Supabase (auth + analytics) ───
# Crea proyecto en https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Emails con acceso admin (separados por coma). También puedes usar is_admin en Supabase.
ADMIN_EMAILS=tu-email@gmail.com

# ─── Afiliados ───

# Amazon Afiliados (amazon.es) — tu tag tipo "tunombre-21"
NEXT_PUBLIC_AMAZON_TAG=

# Awin — tu Publisher ID (número)
NEXT_PUBLIC_AWIN_PUBLISHER_ID=
# Token API (ui.awin.com/awin-api) — sincronizar estado programas
AWIN_ACCESS_TOKEN=
# Opcional: automatizar solicitud de programas (scripts/awin-join-programs.py)
AWIN_EMAIL=
AWIN_PASSWORD=

# Admitad — opcional
NEXT_PUBLIC_ADMITAD_ID=

# TradeTracker — opcional
NEXT_PUBLIC_TRADETRACKER_ID=

# eBay Partner Network — Campaign ID
NEXT_PUBLIC_EBAY_CAMPAIGN_ID=

# AliExpress Portals — código del generador de enlaces (ej. _c3iyuOdJ)
NEXT_PUBLIC_ALIEXPRESS_TRACKING_ID=
# Nombre del tracking ID en el portal (normalmente "default")
NEXT_PUBLIC_ALIEXPRESS_TRACKING_NAME=default

# Booking.com — Affiliate ID
NEXT_PUBLIC_BOOKING_AID=

# URL pública (sitemap, OG, referidos)
NEXT_PUBLIC_SITE_URL=https://deals-hub-iota.vercel.app

# Cron Vercel / GitHub Actions — obligatorio en producción
CRON_SECRET=
